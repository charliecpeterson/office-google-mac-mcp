{
  "mcpServers": {
    "word": {
      "command": "uv",
      "args": ["run", "--directory", "/path/to/repo/packages/office", "office-mcp", "word"]
    },
    "excel": {
      "command": "uv",
      "args": ["run", "--directory", "/path/to/repo/packages/office", "office-mcp", "excel"]
    },
    "powerpoint": {
      "command": "uv",
      "args": ["run", "--directory", "/path/to/repo/packages/office", "office-mcp", "powerpoint"]
    },
    "google-sheets": {
      "command": "uv",
      "args": ["run", "--directory", "/path/to/repo/packages/google", "google-mcp", "sheets"]
    }
  }
}
